# ── Fiomio — environment variables ───────────────────────────
# Copy this file to `.env.local` and fill in what you need.

# Waitlist destination (optional but recommended for production).
# When set, /api/waitlist forwards each signup as JSON to this URL.
# Works with anything that accepts a POST JSON webhook:
#   • Google Sheet  → Apps Script web-app URL
#   • Zapier / Make → "Catch Hook" URL
#   • Formspree     → https://formspree.io/f/xxxxxxx
#   • Resend, Beehiiv, ConvertKit, etc.
# If left empty, signups are stored in ./data/waitlist.json in local dev
# (not persisted on serverless hosting — set this before launch).
WAITLIST_WEBHOOK_URL=

# Beehiiv (preferred: collects emails AND sends the newsletter).
# Beehiiv dashboard → Settings → API → create a key. Publication id is the
# "pub_xxxxxxxx" value (Settings, or the API). These are SERVER-side secrets
# (no NEXT_PUBLIC_). When both are set, /api/waitlist subscribes via Beehiiv.
BEEHIIV_API_KEY=
BEEHIIV_PUBLICATION_ID=

# Sovrn Commerce (ex-Skimlinks) auto-affiliation publisher id.
# Once your site is approved, grab the id from the Sovrn dashboard script
# ( https://s.skimresources.com/js/<THIS_ID>.skimlinks.js ) and set it here.
# When set, every outbound merchant link is auto-converted to an affiliate
# link. Leave empty until approved. Must be NEXT_PUBLIC_ (loads client-side).
NEXT_PUBLIC_SOVRN_ID=

# Direct affiliate tags for KEY retailers (higher commission than Sovrn).
# Optional: set once approved by each program; otherwise Sovrn handles the
# link. The query-param format per program lives in src/lib/affiliates.ts —
# adjust there to match each program's exact instructions.
NEXT_PUBLIC_AFF_AMAZON=      # Amazon Associates store id, e.g. fiomio-21
NEXT_PUBLIC_AFF_YESSTYLE=
NEXT_PUBLIC_AFF_STYLEVANA=
NEXT_PUBLIC_AFF_IHERB=
